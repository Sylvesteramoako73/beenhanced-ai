# Anthropic API key - NEVER expose this to the client
ANTHROPIC_API_KEY=sk-ant-api03-...

# Session encryption secret - generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here-at-least-32-chars

# Sylvester's login password (set by admin)
SYLVESTER_PASSWORD=your-secure-password-here
EMILY_PASSWORD=your-emily-password-here

# Admin (owner) login password
ADMIN_PASSWORD=your-admin-password-here

# Google OAuth for Gmail integration
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Supabase database
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL (for OAuth redirects)
NEXTAUTH_URL=http://localhost:3000
